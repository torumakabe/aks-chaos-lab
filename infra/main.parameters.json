{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "${AZURE_LOCATION:eastus2}"
    },
    "appName": {
      "value": "aks-chaos-lab"
    },
    "environment": {
      "value": "${AZURE_ENV_NAME}"
    },
    "nodeVmSize": {
      "value": "${AZURE_AKS_NODE_VM_SIZE:Standard_D4ds_v7}"
    },
    "vnetAddressPrefix": {
      "value": "10.10.0.0/16"
    },
    "aksSubnetPrefix": {
      "value": "10.10.1.0/24"
    },
    "peSubnetPrefix": {
      "value": "10.10.2.0/24"
    },
    "aksApiSubnetPrefix": {
      "value": "10.10.3.0/28"
    },
    "functionSubnetPrefix": {
      "value": "10.10.4.0/26"
    },
    "kubernetesVersion": {
      "value": "1.34"
    },
    "aksSkuName": {
      "value": "${AKS_SKU_NAME:Base}"
    },
    "enablePrometheusWorkspace": {
      "value": true
    },
    "enablePrometheusPipeline": {
      "value": true
    },
    "enablePrometheusRecordingRules": {
      "value": true
    },
    "enableAzureMonitorSli": {
      "value": true
    },
    "azureMonitorSliParentServiceGroupId": {
      "value": "${AZURE_MONITOR_SLI_PARENT_SERVICE_GROUP_ID:none}"
    },
    "azureMonitorSliServiceGroupResourceId": {
      "value": "${AZURE_MONITOR_SLI_SERVICE_GROUP_RESOURCE_ID:none}"
    },
    "enableChaosExperiments": {
      "value": true
    },
    "enableContainerInsights": {
      "value": true
    },
    "containerInsightsPreset": {
      "value": "Custom"
    },
    "actionGroupId": {
      "value": ""
    },
    "chaosNamespace": {
      "value": "chaos-lab"
    },
    "chaosAppLabel": {
      "value": "chaos-app"
    },
    "chaosDuration": {
      "value": "PT5M"
    }
  }
}
